<% if (errors.length > 0) { %>
          <div class="p-4 mb-4 text-red-700 bg-red-100 border border-red-400 rounded">
            <ul class="list-disc list-inside">
              <% errors.forEach(error => { %>
                <li><%= error %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>