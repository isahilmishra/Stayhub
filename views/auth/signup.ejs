<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  </head>
  <body class="bg-gray-100">
    <%- include('../partials/nav') %>
    <main class="container max-w-2xl p-8 mx-auto mt-8 bg-white rounded-lg shadow-md">
      <h1 class="pb-4 mb-6 text-3xl font-bold text-center text-gray-800 border-b">Create Your Account</h1>
      
      <form action="/signup" method="POST" class="max-w-md mx-auto">
 
        <%- include('../partials/errors') %>
        <!-- Name fields in a flex layout -->
        <div class="flex gap-4 mb-4">
          <div class="flex-1">
            <label for="firstName" class="block mb-1 text-sm font-medium text-gray-700">First Name</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
                <i class="fas fa-user"></i>
              </span>
              <input
                type="text"
                id="firstName"
                name="firstName"
                placeholder="John"
                value="<%= oldInput.firstName ? oldInput.firstName : '' %>"
                class="w-full px-4 py-2 pl-10 transition border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500"
                required />
            </div>
          </div>
          
          <div class="flex-1">
            <label for="lastName" class="block mb-1 text-sm font-medium text-gray-700">Last Name</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
                <i class="fas fa-user"></i>
              </span>
              <input
                type="text"
                id="lastName"
                name="lastName"
                value="<%= oldInput.lastName ? oldInput.lastName : '' %>"
                placeholder="Doe"
                class="w-full px-4 py-2 pl-10 transition border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500" />
            </div>
          </div>
        </div>
        
        <!-- Email field -->
        <div class="mb-4">
          <label for="email" class="block mb-1 text-sm font-medium text-gray-700">Email Address</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
              <i class="fas fa-envelope"></i>
            </span>
            <input
              type="email"
              id="email"
              name="email"
              value="<%= oldInput.email ? oldInput.email : '' %>"
              placeholder="your.email@example.com"
              class="w-full px-4 py-2 pl-10 transition border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500"
              required />
          </div>
        </div>
        
        <!-- Password fields -->
        <div class="mb-4">
          <label for="password" class="block mb-1 text-sm font-medium text-gray-700">Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
              <i class="fas fa-lock"></i>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter Your Password"
              class="w-full px-4 py-2 pl-10 transition border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500"
              required/>
          </div>
        </div>
        
        <div class="mb-5">
          <label for="confirmPassword" class="block mb-1 text-sm font-medium text-gray-700">Confirm Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
              <i class="fas fa-lock"></i>
            </span>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Confirm Your Password"
              class="w-full px-4 py-2 pl-10 transition border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500"
              required/>
          </div>
        </div>

        <!-- User type selection with better styling -->
        <div class="p-4 mb-5 border border-gray-200 rounded-md bg-gray-50">
          <p class="mb-2 text-sm font-medium text-gray-700">I want to register as:</p>
          <div class="flex space-x-6">
            <label class="inline-flex items-center cursor-pointer">
              <input type="radio" name="userType" value="guest" id="guest" class="text-red-500 form-radio focus:ring-red-500" checked="<% oldInput.userType === "guest"%>" />
              <span class="ml-2">Guest</span>
            </label>
            <label class="inline-flex items-center cursor-pointer">
              <input type="radio" name="userType" value="host" id="host" class="text-red-500 form-radio focus:ring-red-500" checked="<% oldInput.userType === "host"%>"/>
              <span class="ml-2">Host</span>
            </label>
          </div>
        </div>

        <!-- Terms and conditions -->
        <div class="mb-6">
          <label class="inline-flex items-center cursor-pointer">
            <input type="checkbox" name="terms" id="terms" class="text-red-500 form-checkbox focus:ring-red-500" required />
            <span class="ml-2 text-gray-700">I agree to the <a href="#" class="text-red-500 hover:underline">terms and conditions</a></span>
          </label>
        </div> 

        <!-- Submit button with animation -->
        <button type="submit" class="flex items-center justify-center w-full py-3 font-medium text-white transition duration-300 bg-red-500 rounded-md hover:bg-red-600 focus:ring-4 focus:ring-red-300">
          <span>Register</span>
          <i class="ml-2 fas fa-arrow-right"></i>
        </button>
        
        <!-- Login link -->
        <p class="mt-4 text-center text-gray-600">
          Already have an account? <a href="/login" class="text-red-500 hover:underline">Log in</a>
        </p>
      </form>
    </main>
  </body>
</html>